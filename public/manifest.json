{
  "manifest_version": 3,
  "name": "Lines Overlay Extension",
  "version": "1.0.0",
  "description": "Overlay de linhas guia para desenvolvimento",
  "permissions": ["activeTab", "scripting"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-script.js"]
    }
  ]
}
